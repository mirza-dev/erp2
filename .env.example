# ── Supabase (Zorunlu) ──────────────────────────────────────────────────
# Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...      # public — client-side güvenli
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # gizli — sadece server-side, RLS'i bypass eder

# ── AI (Zorunlu — /api/ai/parse ve /api/ai/score route'ları) ────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth (Opsiyonel — cron/external API çağrıları) ───────────────────────
CRON_SECRET=                            # Bearer token for /api/alerts/scan, /api/alerts/ai-suggest, /api/parasut/sync-all

# ── Sentry (Opsiyonel — production hata takibi) ──────────────────────────
# sentry.io → New Project → Next.js → DSN kopyala
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx   # tarayıcı hataları
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx               # server/edge hataları (aynı değer)
# Coolify Resource'da staging/production ayrımı için:
# SENTRY_ENVIRONMENT=staging      # veya production; set edilmezse NODE_ENV fallback
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=  # client bundle'a inject; build args ile geçirilir
# Source map upload (.github/workflows/sentry-release.yml CI step'inde kullanılır):
# SENTRY_AUTH_TOKEN=sntrys_...   # sentry.io → Settings → Auth Tokens
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=erp2

# ── Paraşüt (Opsiyonel — muhasebe entegrasyonu) ──────────────────────────
# PARASUT_ENABLED=true  → gerçek sync aktif; DB'ye fatura kaydedilir (production)
# PARASUT_ENABLED=      → sync devre dışı; DB'ye hiçbir şey yazılmaz (staging/dev)
PARASUT_ENABLED=
# Paraşüt Developer Portal → OAuth uygulaması oluştur
PARASUT_CLIENT_ID=
PARASUT_CLIENT_SECRET=
PARASUT_COMPANY_ID=

# ── E-posta Bildirimleri (Opsiyonel — Resend) ───────────────────────────
# resend.com → API Keys → yeni key oluştur
# RESEND_API_KEY veya EMAIL_FROM yoksa e-posta gönderimi devre dışı (fail-safe).
# EMAIL_FROM domain'i Resend'de doğrulanmış olmalı.
# Test için: EMAIL_FROM="KokpitERP <onboarding@resend.dev>"
RESEND_API_KEY=
EMAIL_FROM=
# E-postalardaki "Detayları Görüntüle" CTA linkleri için public app URL
# Coolify production: https://erp.kokpit.app
# Coolify staging:    https://erp-staging.kokpit.app
NEXT_PUBLIC_APP_URL=https://erp.kokpit.app

# ── Coolify deployment (Vercel migration sonrası) ────────────────────────
# GitHub Actions secrets gerektirir (Settings → Secrets → Actions):
#   APP_URL          — production URL (cron endpoint'lerine post için)
#   CRON_SECRET      — Coolify env ile aynı; her cron job için Bearer token
#   NEXT_PUBLIC_*    — sentry-release.yml workflow build için
#   SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT — source map upload

# ── Admin (Opsiyonel — admin user listesi) ──────────────────────────────
# Virgülle ayrılmış e-postalar; admin endpoint'leri için role guard fallback
# ADMIN_EMAILS=admin@kokpit.app,mrzsrbyk06@gmail.com

# ── Faz 2d — Attachments demo guard (Opsiyonel) ─────────────────────────
# true → demo cookie ile anonim GET /api/products/[id]/attachments** = 401.
# Demo bucket SADECE seed/fake data ise gerekmez (default false).
# Prod ile aynı Supabase bucket'ını paylaşan dağıtımlarda 'true' yapın.
# ATTACHMENTS_BLOCK_DEMO_ANON=false
